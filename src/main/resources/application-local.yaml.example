# Google OAuth2 설정
# 이 파일을 application-local.yaml로 복사하고 실제 키를 입력하세요.
# application-local.yaml은 .gitignore에 추가하는 것을 권장합니다.

spring:
  security:
    oauth2:
      client:
        registration:
          google:
            client-id: YOUR_GOOGLE_CLIENT_ID
            client-secret: YOUR_GOOGLE_CLIENT_SECRET
