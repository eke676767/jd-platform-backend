# Kakao OAuth2 설정
# 이 파일을 application-local.yaml로 복사하고 실제 키를 입력하세요.
# application-local.yaml은 .gitignore에 추가하는 것을 권장합니다.

spring:
  security:
    oauth2:
      client:
        registration:
          kakao:
            client-id: YOUR_KAKAO_REST_API_KEY
            client-secret: YOUR_KAKAO_CLIENT_SECRET
